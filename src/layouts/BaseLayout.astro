---
import "../styles/global.css";

interface Props {
  title: string;
  buildMarker?: string;
}

const { title, buildMarker } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="hero">
        <p class="eyebrow">AlecsG77 Portal</p>
        <h1>{title}</h1>
        {buildMarker && <p class="marker">Build marker: {buildMarker}</p>}
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
